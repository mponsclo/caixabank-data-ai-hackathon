# These are some examples of commonly ignored file patterns.
# You should customize this list as applicable to your project.
# Learn more about .gitignore:
#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/
dist/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/
dist/

# IDEs
.idea/
.cursor/
.claude/

# Environment
.env
.env.*

# Python
*.egg-info/
.coverage
htmlcov/
.ipynb_checkpoints/

# Models (global ignore, but outputs/models/ is tracked for Docker CI builds)
*.pkl
!outputs/
!outputs/models/
!outputs/models/*.pkl

# Project
CLAUDE.md

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war

# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

#folders
.venv/
venv/

# data files
data/raw/
data/processed/
data/dbt_output/

# dbt
dbt/target/
dbt/logs/
dbt/dbt_packages/
dbt/.user.yml

# virtual environment
.myenv/
myenv/

# Terraform
terraform/.terraform/
terraform/**/.terraform/
terraform/**/*.tfstate
terraform/**/*.tfstate.backup
terraform/**/*.tfvars
!terraform/**/*.tfvars.enc
terraform/.terraform.lock.hcl
terraform/bootstrap/.terraform.lock.hcl

# Terraform temporary build artifacts (archive_file outputs)
.terraform-tmp/

# Model artifacts — committed so Docker CI builds include them
# Rebuild with: make export-models
# outputs/models/  (intentionally tracked)